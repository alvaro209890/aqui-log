NODE_ENV=development
PORT=3001
# Timezone operacional (trends, dia local, jobs)
APP_TIMEZONE=America/Sao_Paulo

DATABASE_HOST=localhost
# Local costuma ser 5433 se 5432 estiver ocupada (Atlas etc.)
DATABASE_PORT=5433
DATABASE_NAME=aqui_log
DATABASE_USER=aqui_log
DATABASE_PASSWORD=aqui_log_dev
DATABASE_SYNC=false

REDIS_URL=redis://localhost:6379

JWT_SECRET=troque-esta-chave-em-producao
# Access token (curto em prod; 1d ok em dev local)
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_DAYS=30

# Precificacao server-side (centavos)
PRICING_BASE_FEE_CENTS=1000
PRICING_PER_KM_CENTS=500
PRICING_PLATFORM_FEE_PERCENT=20
PRICING_MIN_FEE_CENTS=800

# Ofertas: TTL em segundos (default 120 = 2 min)
OFFER_TTL_SECONDS=120

ADMIN_NAME=Administrador Aqui Log
ADMIN_EMAIL=admin@aquilog.com.br
ADMIN_PASSWORD=TroqueEstaSenha123!

VITE_API_URL=http://localhost:3001/api/v1
